# The Graph Network API key — get one for free at https://thegraph.com/studio/apikeys/
# Required for the AAVE V3 subgraph fetch. Without it the fetcher falls back to
# the (deprecated) hosted endpoint where available.
GRAPH_API_KEY=

# Optional. Used by data/fetch_gas.py for historical gas tracker data.
# If empty, fetch_gas.py uses a constant-mean fallback derived from a bundled CSV.
ETHERSCAN_API_KEY=
